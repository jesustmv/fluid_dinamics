FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1;

vertices
(
    (0 0 0)      //0
    (10 0 0)  //1
    (10 1 0)  //2
    (0 1 0)  //3
    (0 0 0.5)  //4
    (10 0 0.5)  //5
    (10 1 0.5)  //6
    (0 1 0.5)  //7
);

blocks
(
    hex (0 1 2 3 4 5 6 7)
    (30 30 30)
    simpleGrading (1 1 1)
);

defaultPatch
{
    type empty;
}

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (1 5 6 2)
        );
    }
    down
    {
        type symmetryPlane;
        faces
        (
            (0 4 5 1)
        );
    }

    up
    {
        type wall;
        faces
        (
            (3 7 6 2)
        );
    }

    walls
    {
        type empty;
        faces
        (
            (0 1 2 3)
            (4 5 6 7)
        );
    }
);


