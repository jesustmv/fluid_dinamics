FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.001;   // a small initial dissipation

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.001;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 0.001;
        value           uniform 0.001;
    }
    down
    {
        type            symmetryPlane;
    }
    up
    {
        type            zeroGradient;
    }
    walls
    {
        type            empty;
    }
}