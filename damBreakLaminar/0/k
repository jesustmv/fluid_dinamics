FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.01; 

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.01;   // adjust based on inflow turbulence
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 0.01;
        value           uniform 0.01;
    }
    down
    {
        type            symmetryPlane;
    }
    up
    {
        type            zeroGradient;
    }
    walls
    {
        type            empty;          // if 2D
    }
}

